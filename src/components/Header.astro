---
// Custom Starlight header: mimics the previous course-site header with a
// compact utility row above the primary navigation.
import config from 'virtual:starlight/user-config';

import Search from 'virtual:starlight/components/Search';

const shouldRenderSearch =
	config.pagefind ||
	config.components.Search !== '@astrojs/starlight/components/Search.astro';

// Base path, no trailing slash (e.g. "/26SU-ASIAAM-191A").
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const courseTitle =
	typeof config.title === 'string' ? config.title : 'AA191A-Web Development and GIS for Social Change';
const pageTitle = Astro.locals.starlightRoute.entry.data.title ?? courseTitle;
const githubHref = 'https://github.com/albertkun/26SU-ASIAAM-191A/';

const navLinks = [
	{ label: 'Home', href: `${base}/` },
	{ label: 'Weekly Materials', href: `${base}/weekly_materials/` },
	{ label: 'Assignments', href: `${base}/assignments/` },
	{ label: 'Labs', href: `${base}/labs/` },
	{
		label: 'Discussion 🔗',
		href: 'https://github.com/albertkun/26SU-ASIAAM-191A/discussions',
		external: true,
	},
	{ label: 'Syllabus', href: `${base}/syllabus/` },
	{ label: 'Help', href: `${base}/help/` },
];

const current = Astro.url.pathname.replace(/\/$/, '');
function isActive(href: string) {
	const target = href.replace(/\/$/, '');
	if (target === base) return current === base;
	return current === target || current.startsWith(target + '/');
}
---

<div class="header">
	<div class="header-main">
		<a class="brand" href={`${base}/`}>
			<img
				class="brand-logo"
				src="https://albertkun.github.io/24SU-ASIAAM-191A/etc/media/favicon.png"
				alt=""
				width="32"
				height="32"
			/>
			<span class="brand-title">{courseTitle}</span>
		</a>

		<div class="current-page" aria-current="page">{pageTitle}</div>

		<div class="header-actions print:hidden">
			<header-theme-switch>
				<button class="theme-switch" type="button" role="switch" aria-checked="false">
					<span class="sr-only">Toggle dark mode</span>
					<span class="switch-thumb" aria-hidden="true"></span>
				</button>
			</header-theme-switch>
			{shouldRenderSearch && <Search />}
			<a class="github-link" href={githubHref} rel="me">GitHub</a>
		</div>
	</div>

	<nav class="top-nav print:hidden" aria-label="Main">
		{
			navLinks.map((link) => (
				<a
					href={link.href}
					class:list={['top-nav-link', { active: !link.external && isActive(link.href) }]}
					aria-current={!link.external && isActive(link.href) ? 'page' : undefined}
					{...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
				>
					{link.label}
				</a>
			))
		}
	</nav>
</div>

<script>
	class HeaderThemeSwitch extends HTMLElement {
		button = this.querySelector<HTMLButtonElement>('button')!;
		storageKey = 'starlight-theme';

		constructor() {
			super();
			this.sync();
			this.button.addEventListener('click', () => this.toggle());
		}

		getTheme() {
			return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
		}

		sync() {
			this.button.setAttribute('aria-checked', String(this.getTheme() === 'dark'));
		}

		toggle() {
			const nextTheme = this.getTheme() === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = nextTheme;
			localStorage.setItem(this.storageKey, nextTheme);
			(globalThis as any).StarlightThemeProvider?.updatePickers(nextTheme);
			this.sync();
		}
	}

	if (!customElements.get('header-theme-switch')) {
		customElements.define('header-theme-switch', HeaderThemeSwitch);
	}
</script>

<style>
	.header {
		--header-bg: #2774ae;
		--header-fg: #ffffff;
		--header-hover-bg: rgb(255 255 255 / 16%);
		--header-active-bg: #ffffff;
		--header-active-fg: #1a5276;

		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		height: 100%;
		background-color: var(--header-bg);
		color: var(--header-fg);
	}

	.header-main {
		display: grid;
		grid-template-columns: minmax(15rem, 1.2fr) minmax(12rem, 1fr) auto;
		gap: 1.5rem;
		align-items: center;
		min-height: 2.25rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
		color: var(--header-fg);
		font-size: var(--sl-text-lg);
		font-weight: 700;
		line-height: 1.1;
		text-decoration: none;
	}

	.brand:hover,
	.github-link:hover {
		color: var(--header-fg);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.brand-logo {
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		flex: 0 0 auto;
	}

	.brand-title,
	.current-page {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.current-page {
		color: var(--header-fg);
		font-size: var(--sl-text-base);
		font-weight: 600;
		text-align: center;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1rem;
		min-width: 0;
	}

	.header :global(button[data-open-modal]) {
		border-color: rgb(255 255 255 / 36%);
		background-color: rgb(0 0 0 / 18%);
		color: var(--header-fg);
	}

	.header :global(button[data-open-modal]:hover) {
		border-color: rgb(255 255 255 / 72%);
		background-color: var(--header-hover-bg);
		color: var(--header-fg);
	}

	.header :global(button[data-open-modal] > kbd) {
		background-color: rgb(255 255 255 / 18%);
		color: var(--header-fg);
	}

	.theme-switch {
		position: relative;
		display: inline-flex;
		align-items: center;
		width: 2.25rem;
		height: 1.15rem;
		border: 1px solid rgb(255 255 255 / 50%);
		border-radius: 999px;
		padding: 0.125rem;
		background-color: rgb(0 0 0 / 24%);
		cursor: pointer;
	}

	.theme-switch:hover {
		background-color: var(--header-hover-bg);
	}

	.switch-thumb {
		display: block;
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background-color: #ffffff;
		transition: transform 150ms ease;
	}

	.theme-switch[aria-checked='true'] .switch-thumb {
		transform: translateX(1.05rem);
	}

	.github-link {
		color: var(--header-fg);
		font-size: var(--sl-text-sm);
		font-weight: 700;
		text-decoration: none;
	}

	.top-nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		min-width: 0;
		overflow-x: auto;
		scrollbar-width: none;
	}
	.top-nav::-webkit-scrollbar {
		display: none;
	}

	.top-nav-link {
		white-space: nowrap;
		padding: 0.4rem 0.7rem;
		border-radius: 0.5rem;
		font-size: var(--sl-text-sm);
		font-weight: 600;
		color: var(--header-fg);
		text-decoration: none;
		line-height: 1.1;
	}
	.top-nav-link:hover {
		color: var(--header-fg);
		background-color: var(--header-hover-bg);
	}
	.top-nav-link.active {
		color: var(--header-active-fg);
		background-color: var(--header-active-bg);
	}

	@media (max-width: 64rem) {
		.header-main {
			grid-template-columns: 1fr auto;
			gap: 1rem;
		}

		.current-page {
			display: none;
		}
	}

	@media (max-width: 50rem) {
		.header {
			gap: 0.45rem;
		}

		.header-main {
			grid-template-columns: 1fr;
		}

		.brand {
			font-size: var(--sl-text-base);
		}

		.header-actions {
			display: none;
		}

		.top-nav {
			justify-content: flex-start;
		}
	}
</style>