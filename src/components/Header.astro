---
import config from 'virtual:starlight/user-config';

import { Icon } from '@astrojs/starlight/components';
import Search from 'virtual:starlight/components/Search';
import { logos } from 'virtual:starlight/user-images';

const shouldRenderSearch =
	config.pagefind ||
	config.components.Search !== '@astrojs/starlight/components/Search.astro';

// Base path, no trailing slash (e.g. "/26SU-ASIAAM-191A").
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
	{ label: 'Home', href: `${base}/` },
	{ label: 'Weekly Materials', href: `${base}/weekly_materials/` },
	{ label: 'Assignments', href: `${base}/assignments/` },
	{ label: 'Labs', href: `${base}/labs/` },
	{
		label: 'Discussion ↗',
		href: 'https://github.com/albertkun/26SU-ASIAAM-191A/discussions',
		external: true,
	},
	{ label: 'Syllabus', href: `${base}/syllabus/` },
	{ label: 'Help', href: `${base}/help/` },
];

const current = Astro.url.pathname.replace(/\/$/, '');
const { entry, siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
const pageTitle = entry.data.title;
const githubLink = config.social?.find((link) => link.icon === 'github');

function isActive(href: string) {
	const target = href.replace(/\/$/, '');
	if (target === base) return current === base; // Home matches only the root
	return current === target || current.startsWith(target + '/');
}
---

<div class="course-header">
	<div class="header-main">
		<a href={siteTitleHref} class="brand-link" aria-label={siteTitle}>
			{
				config.logo && logos.dark && (
					<img
						class="brand-logo"
						alt={config.logo.alt ?? ''}
						src={logos.dark.src}
						width={logos.dark.width}
						height={logos.dark.height}
					/>
				)
			}
			<span class="brand-text">AA191A-Web Development and GIS for Social Change</span>
		</a>

		<div class="page-title" aria-hidden={pageTitle === 'Home' ? 'true' : undefined}>
			{pageTitle === 'Home' ? '' : pageTitle}
		</div>

		<div class="header-actions print:hidden">
			<course-theme-switch class="theme-switch" data-label={Astro.locals.t('themeSelect.accessibleLabel')}>
				<label>
					<span class="sr-only">{Astro.locals.t('themeSelect.accessibleLabel')}</span>
					<input type="checkbox" aria-label={Astro.locals.t('themeSelect.accessibleLabel')} />
					<span class="switch-track" aria-hidden="true">
						<span class="switch-thumb"></span>
					</span>
				</label>
			</course-theme-switch>

			{shouldRenderSearch && <Search />}

			{
				githubLink && (
					<a class="github-link" href={githubLink.href} rel="me" aria-label={githubLink.label}>
						<Icon name="github" />
						<span>{githubLink.label}</span>
					</a>
				)
			}
		</div>
	</div>

	<nav class="top-nav" aria-label="Main">
		{
			navLinks.map((link) => (
				<a
					href={link.href}
					class:list={['top-nav-link', { active: !link.external && isActive(link.href) }]}
					aria-current={!link.external && isActive(link.href) ? 'page' : undefined}
					{...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
				>
					{link.label}
				</a>
			))
		}
	</nav>
</div>

<script>
	const storageKey = 'starlight-theme';
	type Theme = 'dark' | 'light';

	const parseTheme = (theme: unknown): Theme | undefined =>
		theme === 'dark' || theme === 'light' ? theme : undefined;

	const preferredTheme = (): Theme =>
		matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

	class CourseThemeSwitch extends HTMLElement {
		input = this.querySelector<HTMLInputElement>('input')!;

		constructor() {
			super();
			this.setTheme(this.loadTheme());
			this.input.addEventListener('change', () => this.setTheme(this.input.checked ? 'dark' : 'light'));
		}

		loadTheme(): Theme {
			return (
				parseTheme(localStorage.getItem(storageKey)) ??
				parseTheme(document.documentElement.dataset.theme) ??
				preferredTheme()
			);
		}

		setTheme(theme: Theme) {
			document.documentElement.dataset.theme = theme;
			localStorage.setItem(storageKey, theme);
			this.input.checked = theme === 'dark';
		}
	}

	customElements.define('course-theme-switch', CourseThemeSwitch);
</script>

<style>
	.course-header {
		--header-bg: #2774ae;
		--header-fg: #ffffff;
		--header-fg-muted: #ffffff;
		--header-hover-bg: rgb(255 255 255 / 16%);
		--header-active-bg: rgb(0 0 0 / 18%);
		--header-active-fg: #ffffff;

		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.55rem;
		background-color: var(--header-bg);
		color: var(--header-fg);
	}

	.header-main {
		display: grid;
		grid-template-columns: minmax(16rem, 1fr) minmax(10rem, 0.9fr) minmax(22rem, 1fr);
		align-items: center;
		gap: 1.25rem;
		min-width: 0;
	}

	.brand-link,
	.github-link,
	.top-nav-link {
		color: var(--header-fg);
		text-decoration: none;
	}

	.brand-link {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		min-width: 0;
		font-weight: 700;
		font-size: 1.125rem;
		line-height: 1.2;
	}

	.brand-link:hover,
	.github-link:hover,
	.top-nav-link:hover {
		background-color: var(--header-hover-bg);
		color: var(--header-fg);
	}

	.brand-logo {
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		object-fit: contain;
		flex: 0 0 auto;
	}

	.brand-text {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.page-title {
		overflow: hidden;
		text-align: center;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-size: 1rem;
		font-weight: 600;
		color: rgb(255 255 255 / 78%);
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.8rem;
		min-width: 0;
	}

	.course-header :global(button[data-open-modal]) {
		min-width: 13.5rem;
		border: 0;
		border-radius: 0.1rem;
		background-color: rgb(0 0 0 / 24%);
		color: var(--header-fg);
	}

	.course-header :global(button[data-open-modal]:hover) {
		background-color: var(--header-hover-bg);
		color: var(--header-fg);
	}

	.course-header :global(button[data-open-modal] > kbd) {
		background-color: rgb(255 255 255 / 18%);
		color: var(--header-fg);
	}

	.github-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.4rem 0.55rem;
		border-radius: 0.25rem;
		font-weight: 700;
		line-height: 1;
	}

	.github-link :global(svg) {
		font-size: 1.35rem;
	}

	.theme-switch label {
		display: flex;
		align-items: center;
		cursor: pointer;
	}

	.theme-switch input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.switch-track {
		display: inline-flex;
		align-items: center;
		width: 1.45rem;
		height: 0.75rem;
		padding: 0.12rem;
		border-radius: 999px;
		background-color: rgb(255 255 255 / 82%);
		box-shadow: inset 0 0 0 1px rgb(0 0 0 / 12%);
	}

	.switch-thumb {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background-color: #2774ae;
		transition: transform 160ms ease;
	}

	.theme-switch input:focus-visible + .switch-track {
		outline: 2px solid #ffffff;
		outline-offset: 3px;
	}

	.theme-switch input:checked + .switch-track .switch-thumb {
		transform: translateX(0.7rem);
	}

	.top-nav {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		min-width: 0;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.top-nav::-webkit-scrollbar {
		display: none;
	}

	.top-nav-link {
		white-space: nowrap;
		padding: 0.35rem 0.7rem;
		border-radius: 0.25rem;
		font-size: var(--sl-text-base);
		font-weight: 500;
		color: var(--header-fg-muted);
		line-height: 1.1;
	}

	.top-nav-link.active {
		color: var(--header-active-fg);
		background-color: var(--header-active-bg);
		font-weight: 700;
	}

	@media (max-width: 72rem) {
		.header-main {
			grid-template-columns: minmax(14rem, 1fr) minmax(16rem, auto);
		}

		.page-title {
			display: none;
		}
	}

	@media (max-width: 50rem) {
		.course-header {
			gap: 0.4rem;
		}

		.header-main {
			display: flex;
			gap: 0.75rem;
		}

		.brand-text,
		.github-link span,
		.course-header :global(button[data-open-modal] span),
		.course-header :global(button[data-open-modal] kbd) {
			display: none;
		}

		.course-header :global(button[data-open-modal]) {
			min-width: 0;
			width: 2.25rem;
			justify-content: center;
		}

		.header-actions {
			margin-inline-start: auto;
			gap: 0.45rem;
		}

		.top-nav-link {
			font-size: var(--sl-text-sm);
			padding-inline: 0.55rem;
		}
	}
</style>
