---
// Custom Starlight header: mimics the previous course-site header with a
// compact utility row above the primary navigation.
import config from 'virtual:starlight/user-config';
import logo from '../assets/favicon.png';

import Search from 'virtual:starlight/components/Search';

const shouldRenderSearch =
	config.pagefind ||
	config.components.Search !== '@astrojs/starlight/components/Search.astro';

// Base path, no trailing slash (e.g. "/26SU-ASIAAM-191A").
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const courseTitle = 'AA191A-Web Development and GIS for Social Change';
const githubHref = 'https://github.com/albertkun/26SU-ASIAAM-191A/';

const navLinks = [
	{ label: 'Home', href: `${base}/` },
	{ label: 'Weekly Materials', href: `${base}/weekly_materials/` },
	{ label: 'Assignments', href: `${base}/assignments/` },
	{ label: 'Labs', href: `${base}/labs/` },
	{
		label: 'Discussion 🔗',
		href: 'https://github.com/albertkun/26SU-ASIAAM-191A/discussions',
		external: true,
	},
	{ label: 'Syllabus', href: `${base}/syllabus/` },
	{ label: 'Help', href: `${base}/help/` },
];

const current = Astro.url.pathname.replace(/\/$/, '');
function isActive(href: string) {
	const target = href.replace(/\/$/, '');
	if (target === base) return current === base;
	return current === target || current.startsWith(target + '/');
}
---

<div class="header">
	<div class="header-main">
		<a class="brand" href={`${base}/`}>
			<img
				class="brand-logo"
				src={logo.src}
				alt=""
				width="32"
				height="32"
			/>
			<span class="brand-title">{courseTitle}</span>
		</a>

		<div class="header-actions print:hidden">
			<header-theme-switch>
				<button class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
					<svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="4.2" fill="currentColor" />
						<g stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
							<line x1="12" y1="2.5" x2="12" y2="5" />
							<line x1="12" y1="19" x2="12" y2="21.5" />
							<line x1="2.5" y1="12" x2="5" y2="12" />
							<line x1="19" y1="12" x2="21.5" y2="12" />
							<line x1="5.1" y1="5.1" x2="6.9" y2="6.9" />
							<line x1="17.1" y1="17.1" x2="18.9" y2="18.9" />
							<line x1="5.1" y1="18.9" x2="6.9" y2="17.1" />
							<line x1="17.1" y1="6.9" x2="18.9" y2="5.1" />
						</g>
					</svg>
					<svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true">
						<path
							fill="currentColor"
							d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z"
						></path>
					</svg>
				</button>
			</header-theme-switch>
			{shouldRenderSearch && <Search />}
			<a class="github-link" href={githubHref} rel="me" aria-label="GitHub repository">
				<svg class="github-icon" viewBox="0 0 16 16" aria-hidden="true">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.65 7.65 0 0 1 8 3.86c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
					/>
				</svg>
				<span class="github-copy">
					<span class="github-label">GitHub</span>
					<span class="github-stats" data-github-stats>
						<span class="github-stat">
							<svg class="github-stat-icon" viewBox="0 0 16 16" aria-hidden="true">
								<path
									fill="currentColor"
									d="M8 1.2 9.9 5.3l4.5.5-3.3 3 1 4.4L8 10.9l-4.1 2.3 1-4.4-3.3-3 4.5-.5L8 1.2Z"
								/>
							</svg>
							<span class="sr-only">Stars</span>
							<span data-github-stars>0</span>
						</span>
						<span class="github-stat">
							<svg class="github-stat-icon" viewBox="0 0 16 16" aria-hidden="true">
								<path
									fill="none"
									stroke="currentColor"
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="1.7"
									d="M5 4.2v3.1c0 1.4 1.1 2.5 2.5 2.5H11M11 3.7v8.6"
								/>
								<circle cx="5" cy="3" r="1.7" fill="currentColor" />
								<circle cx="11" cy="3" r="1.7" fill="currentColor" />
								<circle cx="11" cy="13" r="1.7" fill="currentColor" />
							</svg>
							<span class="sr-only">Forks</span>
							<span data-github-forks>0</span>
						</span>
					</span>
				</span>
			</a>
		</div>
	</div>

	<nav class="top-nav print:hidden" aria-label="Main">
		{
			navLinks.map((link) => (
				<a
					href={link.href}
					class:list={['top-nav-link', { active: !link.external && isActive(link.href) }]}
					aria-current={!link.external && isActive(link.href) ? 'page' : undefined}
					{...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
				>
					{link.label}
				</a>
			))
		}
	</nav>
</div>

<script>
	class HeaderThemeSwitch extends HTMLElement {
		button = this.querySelector<HTMLButtonElement>('button')!;
		storageKey = 'starlight-theme';

		constructor() {
			super();
			this.sync();
			this.button.addEventListener('click', () => this.toggle());
		}

		getTheme() {
			return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
		}

		sync() {
			const label =
				this.getTheme() === 'dark' ? 'Switch to light theme' : 'Switch to dark theme';
			this.button.setAttribute('aria-label', label);
			this.button.setAttribute('title', label);
		}

		toggle() {
			const nextTheme = this.getTheme() === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = nextTheme;
			localStorage.setItem(this.storageKey, nextTheme);
			(globalThis as any).StarlightThemeProvider?.updatePickers(nextTheme);
			this.sync();
		}
	}

	if (!customElements.get('header-theme-switch')) {
		customElements.define('header-theme-switch', HeaderThemeSwitch);
	}

	const stars = document.querySelector<HTMLElement>('[data-github-stars]');
	const forks = document.querySelector<HTMLElement>('[data-github-forks]');
	if (stars && forks) {
		fetch('https://api.github.com/repos/albertkun/26SU-ASIAAM-191A')
			.then((response) => (response.ok ? response.json() : undefined))
			.then((repo) => {
				if (!repo) return;
				stars.textContent = String(repo.stargazers_count ?? 0);
				forks.textContent = String(repo.forks_count ?? 0);
			})
			.catch(() => {});
	}
</script>

<style>
	.header {
		--header-bg: #2774ae;
		--header-fg: #ffffff;
		--header-fg-muted: rgb(255 255 255 / 72%);
		--header-hover-bg: rgb(255 255 255 / 16%);

		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		box-sizing: border-box;
		width: 100%;
		max-width: 86rem;
		height: 100%;
		margin-inline: auto;
		background-color: var(--header-bg);
		color: var(--header-fg);
	}

	.header-main {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: center;
		min-height: 2.25rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		justify-self: start;
		width: fit-content;
		max-width: 100%;
		min-width: 0;
		color: var(--header-fg);
		font-size: var(--sl-text-lg);
		font-weight: 700;
		line-height: 1.1;
		text-decoration: none;
	}

	.brand:hover,
	.github-link:hover {
		color: var(--header-fg);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.brand-logo {
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		flex: 0 0 auto;
	}

	.brand-title {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1rem;
		flex: 0 0 auto;
		min-width: 0;
	}

	.header :global(button[data-open-modal]) {
		border-color: rgb(255 255 255 / 36%);
		background-color: rgb(0 0 0 / 18%);
		color: var(--header-fg);
		max-width: 17rem;
	}

	.header :global(button[data-open-modal]:hover) {
		border-color: rgb(255 255 255 / 72%);
		background-color: var(--header-hover-bg);
		color: var(--header-fg);
	}

	.header :global(button[data-open-modal] > kbd) {
		background-color: rgb(255 255 255 / 18%);
		color: var(--header-fg);
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: 1px solid rgb(255 255 255 / 36%);
		border-radius: 50%;
		background-color: rgb(0 0 0 / 18%);
		color: var(--header-fg);
		cursor: pointer;
	}

	.theme-toggle:hover {
		border-color: rgb(255 255 255 / 72%);
		background-color: var(--header-hover-bg);
	}

	.theme-icon {
		display: block;
		width: 1.15rem;
		height: 1.15rem;
	}

	/* Show the sun while dark mode is active (click → light) and the moon while
	   light mode is active (click → dark). Starlight defaults to dark. */
	.theme-icon--moon {
		display: none;
	}
	:global(html[data-theme='light']) .theme-icon--sun {
		display: none;
	}
	:global(html[data-theme='light']) .theme-icon--moon {
		display: block;
	}

	.github-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		flex: 0 0 auto;
		min-width: 5.5rem;
		color: var(--header-fg);
		font-size: var(--sl-text-sm);
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
	}

	.github-icon {
		width: 1.5rem;
		height: 1.5rem;
		flex: 0 0 auto;
	}

	.github-copy {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.github-label {
		white-space: nowrap;
	}

	.github-stats {
		display: flex;
		gap: 0.45rem;
		color: var(--header-fg-muted);
		font-size: var(--sl-text-xs);
		font-weight: 600;
		white-space: nowrap;
	}

	.github-stat {
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
	}

	.github-stat-icon {
		width: 0.9rem;
		height: 0.9rem;
		flex: 0 0 auto;
	}

	.top-nav {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 0.4rem;
		min-width: 0;
		overflow-x: auto;
		scrollbar-width: none;
	}
	.top-nav::-webkit-scrollbar {
		display: none;
	}

	.top-nav-link {
		white-space: nowrap;
		padding: 0.4rem 0.7rem;
		border-radius: 0.5rem;
		font-size: var(--sl-text-sm);
		font-weight: 600;
		color: var(--header-fg-muted);
		text-decoration: none;
		line-height: 1.1;
	}
	.top-nav-link:hover {
		color: var(--header-fg);
		background-color: var(--header-hover-bg);
	}
	.top-nav-link.active {
		color: var(--header-fg);
		background-color: transparent;
	}

	@media (max-width: 64rem) {
		.header-main {
			grid-template-columns: 1fr auto;
			gap: 1rem;
		}
	}

	@media (max-width: 50rem) {
		.header {
			gap: 0.45rem;
		}

		.header-main {
			grid-template-columns: 1fr;
		}

		.brand {
			font-size: var(--sl-text-base);
		}

		.header-actions {
			display: none;
		}

		.top-nav {
			justify-content: flex-start;
		}
	}
</style>