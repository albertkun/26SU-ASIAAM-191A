---
interface TocItem {
	slug: string;
	text: string;
}

interface Props {
	entries: any[];
	tocItems?: TocItem[];
	nested?: boolean;
}

const { entries, tocItems = [], nested = false } = Astro.props;
const isLabsSection = Astro.url.pathname.includes('/labs/');

function hasCurrentInEntries(es: any[]): boolean {
	return es.some(e => e.type === 'link' ? e.isCurrent : hasCurrentInEntries(e.entries));
}

// First descendant link href of an entry (for prefix-matching the overview page).
function firstHref(e: any): string | undefined {
	if (e.type === 'link') return e.href;
	for (const c of e.entries) {
		const h = firstHref(c);
		if (h) return h;
	}
	return undefined;
}

// The "overview" page of a group: the child link whose URL is a path-prefix of
// every other entry in the group (i.e. the directory's index page).
function findOverview(es: any[]): any | undefined {
	const links = es.filter(e => e.type === 'link');
	return links.find(l => {
		const others = es.filter(e => e !== l);
		return others.length > 0 && others.every(o => {
			const h = firstHref(o);
			return h != null && h.startsWith(l.href);
		});
	});
}

// Numeric week ordering: "Week 0" < "Week 1" < … (entries without a number keep
// their relative order and sort ahead of numbered ones, e.g. an "Overview" link).
function weekKey(e: any): number | null {
	const label: string = e.label ?? '';
	const m = label.match(/week\s*(\d+)/i) ?? label.match(/^\s*(\d+)/);
	return m ? parseInt(m[1], 10) : null;
}

// Autogenerated groups use the raw directory name (e.g. "week1") as their label;
// prettify "weekN" → "Week N" for display.
function groupLabel(label: string): string {
	const m = label.match(/^week\s*(\d+)$/i);
	return m ? `Week ${m[1]}` : label;
}

const sorted = [...entries].sort((a, b) => {
	const ka = weekKey(a), kb = weekKey(b);
	if (ka === null && kb === null) return 0;
	if (ka === null) return -1;
	if (kb === null) return 1;
	return ka - kb;
});
---

<ul class:list={{ 'top-level': !nested }}>
	{sorted.map((entry) => {
		// Nested subgroups (e.g. "Week 1") with an overview/index page render as a
		// link to that overview instead of an expand/collapse toggle.
		const overview = entry.type !== 'link' && nested ? findOverview(entry.entries) : undefined;
		return (
			<li>
				{entry.type === 'link' ? (
					<>
						<a
							href={entry.href}
							aria-current={entry.isCurrent ? 'page' : undefined}
							class:list={[{ large: !nested }, entry.attrs?.class]}
						>
							<span>{entry.label}</span>
						</a>
						{entry.isCurrent && !isLabsSection && tocItems.length > 0 && (
							<ul class="toc-items">
								{tocItems.map(item => (
									<li>
										<a href={'#' + item.slug}>{item.text}</a>
									</li>
								))}
							</ul>
						)}
					</>
				) : overview ? (
					<>
						<a
							href={overview.href}
							aria-current={overview.isCurrent ? 'page' : undefined}
							class="large group-link"
						>
							<span>{groupLabel(entry.label)}</span>
						</a>
						{overview.isCurrent && !isLabsSection && tocItems.length > 0 && (
							<ul class="toc-items">
								{tocItems.map(item => (
									<li>
										<a href={'#' + item.slug}>{item.text}</a>
									</li>
								))}
							</ul>
						)}
						<Astro.self entries={entry.entries.filter((e: any) => e !== overview)} tocItems={tocItems} nested />
					</>
				) : (
					<details open={hasCurrentInEntries(entry.entries) || !entry.collapsed}>
						<summary>
							<div class="group-label">
								<span class="large">{groupLabel(entry.label)}</span>
							</div>
							<svg aria-hidden="true" class="caret" width="1.25rem" height="1.25rem" viewBox="0 0 24 24" fill="currentColor"><path d="m14.83 11.29-4.24-4.24a1 1 0 1 0-1.42 1.41L12.71 12l-3.54 3.54a1 1 0 0 0 0 1.41 1 1 0 0 0 .71.29 1 1 0 0 0 .71-.29l4.24-4.24a1.002 1.002 0 0 0 0-1.42Z"/></svg>
						</summary>
						<Astro.self entries={entry.entries} tocItems={tocItems} nested />
					</details>
				)}
			</li>
		);
	})}
</ul>

<style>
	ul {
		--sl-sidebar-item-padding-inline: 0.5rem;
		list-style: none;
		padding: 0;
	}
	li {
		overflow-wrap: anywhere;
	}
	ul ul li {
		margin-inline-start: var(--sl-sidebar-item-padding-inline);
		border-inline-start: 1px solid var(--sl-color-hairline-light);
		padding-inline-start: var(--sl-sidebar-item-padding-inline);
	}
	.large {
		font-size: var(--sl-text-lg);
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.top-level > li + li {
		margin-top: 0.75rem;
	}
	summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.2em var(--sl-sidebar-item-padding-inline);
		line-height: 1.4;
		cursor: pointer;
		user-select: none;
	}
	summary::marker,
	summary::-webkit-details-marker {
		display: none;
	}
	.caret {
		transition: transform 0.2s ease-in-out;
		flex-shrink: 0;
	}
	[open] > summary .caret {
		transform: rotateZ(90deg);
	}
	a {
		display: block;
		border-radius: 0.25rem;
		text-decoration: none;
		color: var(--sl-color-gray-2);
		padding: 0.3em var(--sl-sidebar-item-padding-inline);
		line-height: 1.4;
	}
	a.group-link {
		color: var(--sl-color-white);
		padding: 0.2em var(--sl-sidebar-item-padding-inline);
	}
	a.group-link:hover,
	a.group-link:focus {
		color: var(--sl-color-white);
	}
	a:hover,
	a:focus {
		color: var(--sl-color-white);
	}
	[aria-current='page'],
	[aria-current='page']:hover,
	[aria-current='page']:focus {
		font-weight: 600;
		color: var(--sl-color-text-invert);
		background-color: var(--sl-color-text-accent);
	}
	@media (min-width: 50rem) {
		.top-level > li + li {
			margin-top: 0.5rem;
		}
		.large {
			font-size: var(--sl-text-base);
		}
		a {
			font-size: var(--sl-text-sm);
		}
	}
</style>
