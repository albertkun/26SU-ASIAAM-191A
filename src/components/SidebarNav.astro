---
interface Props {
	entries: any[];
	nested?: boolean;
}

const { entries, nested = false } = Astro.props;

function hasCurrentInEntries(es: any[]): boolean {
	return es.some(e => e.type === 'link' ? e.isCurrent : hasCurrentInEntries(e.entries));
}

// First descendant link href of an entry (for prefix-matching the overview page).
function firstHref(e: any): string | undefined {
	if (e.type === 'link') return e.href;
	for (const c of e.entries) {
		const h = firstHref(c);
		if (h) return h;
	}
	return undefined;
}

// The "overview" page of a group: the child link whose URL is a path-prefix of
// every other entry in the group (i.e. the directory's index page).
function findOverview(es: any[]): any | undefined {
	const links = es.filter(e => e.type === 'link');
	return links.find(l => {
		const others = es.filter(e => e !== l);
		return others.length > 0 && others.every(o => {
			const h = firstHref(o);
			return h != null && h.startsWith(l.href);
		});
	});
}

// Numeric week ordering: "Week 0" < "Week 1" < … (entries without a number keep
// their relative order and sort ahead of numbered ones, e.g. an "Overview" link).
function weekKey(e: any): number | null {
	const label: string = e.label ?? '';
	const m = label.match(/week\s*(\d+)/i) ?? label.match(/^\s*(\d+)/);
	return m ? parseInt(m[1], 10) : null;
}

// Autogenerated groups use the raw directory name (e.g. "week1") as their label;
// prettify "weekN" → "Week N" for display.
function groupLabel(label: string): string {
	const m = label.match(/^week\s*(\d+)$/i);
	return m ? `Week ${m[1]}` : label;
}

const sorted = [...entries].sort((a, b) => {
	const ka = weekKey(a), kb = weekKey(b);
	if (ka === null && kb === null) return 0;
	if (ka === null) return -1;
	if (kb === null) return 1;
	return ka - kb;
});
---

<ul class:list={{ 'top-level': !nested }}>
	{sorted.map((entry) => {
		// Any group with an overview/index page — the top-level section root (e.g.
		// "Labs") as well as nested subgroups (e.g. "Week 1") — renders as a link to
		// that overview instead of an expand/collapse toggle. Groups without an index
		// page still fall through to the collapsible <details> below.
		const overview = entry.type !== 'link' ? findOverview(entry.entries) : undefined;
		return (
			<li>
				{entry.type === 'link' ? (
					<a
						href={entry.href}
						aria-current={entry.isCurrent ? 'page' : undefined}
						class:list={[{ large: !nested }, entry.attrs?.class]}
					>
						<span>{entry.label}</span>
					</a>
				) : overview ? (
					<>
						<a
							href={overview.href}
							aria-current={overview.isCurrent ? 'page' : undefined}
							class="large group-link"
						>
							<span>{groupLabel(entry.label)}</span>
						</a>
						{/* Accordion: a nested subgroup (e.g. "Week 2") only reveals its
						    children when it contains the current page. The top-level section
						    root (!nested) always reveals its subgroups. This keeps at most one
						    week expanded and nothing expanded on the section overview page. */}
						{(!nested || hasCurrentInEntries(entry.entries)) && (
							<Astro.self entries={entry.entries.filter((e: any) => e !== overview)} nested />
						)}
					</>
				) : (
					<details open={!nested || hasCurrentInEntries(entry.entries)}>
						<summary>
							<div class="group-label">
								<span class="large">{groupLabel(entry.label)}</span>
							</div>
							<svg aria-hidden="true" class="caret" width="1.25rem" height="1.25rem" viewBox="0 0 24 24" fill="currentColor"><path d="m14.83 11.29-4.24-4.24a1 1 0 1 0-1.42 1.41L12.71 12l-3.54 3.54a1 1 0 0 0 0 1.41 1 1 0 0 0 .71.29 1 1 0 0 0 .71-.29l4.24-4.24a1.002 1.002 0 0 0 0-1.42Z"/></svg>
						</summary>
						<Astro.self entries={entry.entries} nested />
					</details>
				)}
			</li>
		);
	})}
</ul>

<style>
	ul {
		--sl-sidebar-item-padding-inline: 0.5rem;
		list-style: none;
		padding: 0;
	}
	li {
		overflow-wrap: anywhere;
	}
	ul ul li {
		margin-inline-start: var(--sl-sidebar-item-padding-inline);
		border-inline-start: 1px solid var(--sl-color-hairline-light);
		padding-inline-start: var(--sl-sidebar-item-padding-inline);
	}
	.large {
		font-size: var(--sl-text-lg);
		font-weight: 600;
		color: var(--sl-color-white);
	}
	.top-level > li + li {
		margin-top: 0.75rem;
	}
	summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.2em var(--sl-sidebar-item-padding-inline);
		line-height: 1.4;
		cursor: pointer;
		user-select: none;
	}
	summary::marker,
	summary::-webkit-details-marker {
		display: none;
	}
	.caret {
		transition: transform 0.2s ease-in-out;
		flex-shrink: 0;
	}
	[open] > summary .caret {
		transform: rotateZ(90deg);
	}
	a {
		display: block;
		border-radius: 0.25rem;
		text-decoration: none;
		color: var(--sl-color-gray-1);
		padding: 0.3em var(--sl-sidebar-item-padding-inline);
		line-height: 1.4;
	}
	a.group-link {
		color: var(--sl-color-white);
		padding: 0.2em var(--sl-sidebar-item-padding-inline);
	}
	a:hover,
	a:focus,
	a.group-link:hover,
	a.group-link:focus {
		color: var(--sl-color-white);
		background-color: var(--sl-color-gray-6);
	}
	/* The active item gets the accent background with inverted (white in light
	   mode) text. Selectors are qualified with `a`/`a.group-link` so they win over
	   the near-black `a.group-link` color rule above — otherwise the highlighted
	   root reads as black-on-blue. */
	a[aria-current='page'],
	a[aria-current='page']:hover,
	a[aria-current='page']:focus,
	a.group-link[aria-current='page'],
	a.group-link[aria-current='page']:hover,
	a.group-link[aria-current='page']:focus {
		font-weight: 600;
		color: var(--sl-color-text-invert);
		background-color: var(--sl-color-text-accent);
	}
	/* Light mode: darken the active-item blue (accent-high → #1a5276) and force
	   crisp white text. In this theme --sl-color-text-invert resolves to a light
	   blue (accent-low), so we set white explicitly here — scoped to light mode so
	   dark mode keeps its own theme-correct inverted text. */
	:global([data-theme='light']) a[aria-current='page'],
	:global([data-theme='light']) a[aria-current='page']:hover,
	:global([data-theme='light']) a[aria-current='page']:focus,
	:global([data-theme='light']) a.group-link[aria-current='page'],
	:global([data-theme='light']) a.group-link[aria-current='page']:hover,
	:global([data-theme='light']) a.group-link[aria-current='page']:focus {
		background-color: var(--sl-color-accent-high);
		color: #fff;
	}
	@media (min-width: 50rem) {
		.top-level > li + li {
			margin-top: 0.5rem;
		}
		.large {
			font-size: var(--sl-text-base);
		}
		a {
			font-size: var(--sl-text-sm);
		}
	}
</style>
