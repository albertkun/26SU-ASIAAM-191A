---
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import TableOfContents from 'virtual:starlight/components/TableOfContents';

const { sidebar, toc } = Astro.locals.starlightRoute;
// Only show the TOC when the page has more than 2 top-level headings.
const showToc = toc && toc.items.length > 2;
---

<SidebarPersister>
	<SidebarSublist sublist={sidebar} />
</SidebarPersister>

{showToc && (
	<div class="toc-section">
		<hr />
		<TableOfContents />
	</div>
)}

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<style>
	.toc-section {
		margin-top: 1rem;
	}
	.toc-section hr {
		border: none;
		border-top: 1px solid var(--sl-color-hairline-light);
		margin-bottom: 1rem;
	}
</style>
