---
interface NavLink {
  href: string;
  label: string;
}

interface Props {
  prev?: NavLink;
  next?: NavLink;
}

const { prev, next } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolve = (href: string) => href.startsWith('/') ? base + href : href;
---

<nav class="lab-nav" aria-label="Lab navigation">
  {prev
    ? <a href={resolve(prev.href)} class="lab-nav-btn lab-nav-prev">← {prev.label}</a>
    : <span class="lab-nav-spacer"></span>
  }
  {next
    ? <a href={resolve(next.href)} class="lab-nav-btn lab-nav-next">{next.label} →</a>
    : <span class="lab-nav-spacer"></span>
  }
</nav>
